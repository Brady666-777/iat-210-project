21:T769,graph TD
  Start([Game Start]) --> Setup[Setup Board and Player Initial States]
  Setup --> TurnStart{Begin Turn}

  TurnStart --> SunPhase[Phase 1: Sun Tribute]
  SunPhase --> RollDice[Roll 2 dice, get Tribute Value N]
  RollDice --> AllPay[All players collectively pay N resources]
  AllPay --> Check{Total Paid >= N?}

  Check -- Yes --> NoPunish[No effect, continue]
  Check -- No --> Punish[Draw Sun Punishment card and execute]
  Punish --> FailCount[Failure Count +1]
  FailCount --> CheckFail{Total Failures = 3?}
  CheckFail -- Yes --> Lose[All players lose, game over]
  CheckFail -- No --> NoPunish

  NoPunish --> CurrentPlayer[Current player's turn]
  CurrentPlayer --> MovePhase[Phase 2: Movement]
  MovePhase --> ConsumeFuel[Consume Fuel Turian passive cost halved]
  ConsumeFuel --> MoveDice[Roll dice for movement steps]
  MoveDice --> Move[Move steps, trigger passing grid effects]
  Move --> LandEffect[Phase 3: Landing Grid Effect]
  LandEffect --> CheckCell{Grid Type}

  CheckCell -- Resource Point --> Mine[Roll dice for mining, gain resources]
  CheckCell -- Danger Zone --> DrawAction[Draw Action card and execute]
  CheckCell -- Special Grid --> Special[Execute special effect trade warp etc]
  CheckCell -- Black Market --> BlackMarket[Draw/Purchase Sabotage card]

  LandEffect --> ActionPhase[Phase 4: Action Phase]
  ActionPhase --> Options{Choose Actions}
  Options --> RaceSkill[Use Racial Active Skill]
  Options --> Sabotage[Play Sabotage card]
  Options --> Trade[Trade resources]
  Options --> Build[Construct Ark]

  RaceSkill --> ActionEnd
  Sabotage --> ActionEnd
  Trade --> ActionEnd
  Build --> CheckWin{Ark completed?}
  CheckWin -- Yes --> Win[Player wins!]
  CheckWin -- No --> ActionEnd

  ActionEnd --> EndPhase[Phase 5: End of Turn]
  EndPhase --> HandLimit[Check hand limit]
  HandLimit --> NextPlayer[Next player's turn]
  NextPlayer --> TurnStart9:["$","section",null,{"className":"reveal-up max-w-4xl mx-auto mb-16","style":{"--reveal-delay":"920ms"},"children":["$","details",null,{"className":"chart-frame floating-card bg-[#1a1a1a] rounded-xl border border-[#2a2a2a]","children":[["$","summary",null,{"className":"list-none cursor-pointer px-4 md:px-6 py-4 md:py-5","children":[["$","h2",null,{"className":"text-3xl font-bold text-white tracking-wider","children":"Game Flow Chart"}],["$","p",null,{"className":"text-gray-400 mt-2 leading-relaxed","children":"Click to expand or collapse the turn flow diagram."}]]}],["$","div",null,{"className":"px-4 md:px-6 pb-4 md:pb-6 overflow-x-auto","children":["$","$L20",null,{"chart":"$21","className":"min-w-[900px] text-white"}]}]]}]}]
