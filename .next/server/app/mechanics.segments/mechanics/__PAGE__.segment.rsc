13:["$","section",null,{"className":"reveal-up max-w-4xl mx-auto mb-16","style":{"--reveal-delay":"1700ms"},"children":[["$","h2",null,{"className":"text-3xl font-bold text-white mb-6 tracking-wider","children":"Game Dynamics"}],["$","div",null,{"className":"space-y-4","children":[["$","div",null,{"className":"floating-card reveal-scale bg-[#1a1a1a] rounded-xl p-6 border border-[#2a2a2a]","style":{"--reveal-delay":"1760ms"},"children":[["$","h3",null,{"className":"text-white font-bold mb-2","children":"Cooperative Tension"}],["$","p",null,{"className":"text-gray-400 text-sm leading-relaxed","children":"The Solar Sacrifice forces rivals to cooperate temporarily every single round. There is no escaping it. Fail collectively and everyone suffers. This creates genuine diplomatic moments even in a highly competitive game, as players must weigh mutual survival against beating each other to Ark completion."}]]}],["$","div",null,{"className":"floating-card reveal-scale bg-[#1a1a1a] rounded-xl p-6 border border-[#2a2a2a]","style":{"--reveal-delay":"1820ms"},"children":[["$","h3",null,{"className":"text-white font-bold mb-2","children":"Spatial Control"}],["$","p",null,{"className":"text-gray-400 text-sm leading-relaxed","children":"Landing on an opponent tile costs you a resource. This discourages players from clustering together and naturally spreads the field. Controlling the high-value 2x bonus tiles (Tiles 14, 16, 18) creates a positional advantage that others must work around or spend Sabotage Cards to disrupt."}]]}],["$","div",null,{"className":"floating-card reveal-scale bg-[#1a1a1a] rounded-xl p-6 border border-[#2a2a2a]","style":{"--reveal-delay":"1880ms"},"children":[["$","h3",null,{"className":"text-white font-bold mb-2","children":"Asymmetric Faction Interplay"}],["$","p",null,{"className":"text-gray-400 text-sm leading-relaxed","children":"Each faction wants different resources and excels at different board areas. Asari and Salarians compete for Crystals; Turian and Krogan compete for Metal and Fuel. This natural competition creates faction-specific hotspots and encourages targeted sabotage against direct resource rivals."}]]}],["$","div",null,{"className":"floating-card reveal-scale bg-[#1a1a1a] rounded-xl p-6 border border-[#2a2a2a]","style":{"--reveal-delay":"1940ms"},"children":[["$","h3",null,{"className":"text-white font-bold mb-2","children":"Escalating Endgame"}],["$","p",null,{"className":"text-gray-400 text-sm leading-relaxed","children":"As players fill more Ark slots, the temptation to play Sabotage Cards increases dramatically. Late-game turns become a high-stakes battle of card-playing and resource denial, with the Failure Track serving as a ticking clock that punishes any faction that over-commits to aggression at the expense of collective survival."}]]}]]}]]}]
