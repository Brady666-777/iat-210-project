f:["$","section",null,{"className":"reveal-up max-w-4xl mx-auto mb-16","style":{"--reveal-delay":"1280ms"},"children":[["$","h2",null,{"className":"text-3xl font-bold text-white mb-6 tracking-wider","children":"Quantitative Analysis"}],["$","div",null,{"className":"space-y-6 text-gray-400 leading-relaxed","children":[["$","p",null,{"children":"Playtesting across four-player sessions revealed that the Solar Sacrifice creates a measurable free-rider dynamic when the Tribute Value exceeds 8. Players on low resources deliberately under-contribute, hoping others will carry the shortfall. This emergent behaviour adds a compelling psychological layer but can slow the early game."}],["$","p",null,{"children":"Turn length typically ranges from 45 seconds to 3 minutes. Early turns are fast as players simply move and mine. Mid-to-late game decisions including when to build Ark slots, when to play Sabotage Cards, and how much to contribute to Solar Sacrifice increase decision time significantly."}],["$","p",null,{"children":"The Krogan faction showed the highest swing potential: their Hardcore Charge teleport combined with a 2x Fuel Depot can generate up to 9 or more Fuel in a single turn, immediately transforming them from resource-poor to resource-dominant. This required careful map tile placement to prevent the Lab tile from being trivially exploitable."}],["$","p",null,{"children":"The Human passive (penalty halved on failed sacrifice) proved to be a strong equaliser during resource droughts, keeping them competitive in rounds where other factions took heavy Solar Flare losses."}],["$","p",null,{"children":"Ark slot costs were calibrated so that the average player can complete their track in approximately 8 to 12 rounds, giving enough time for meaningful interaction without the game dragging. The Krogan track is the most resource-intensive at 3 to 4 Metal per slot but rewards aggressive early mining."}]]}]]}]
10:["$","div",null,{"className":"divider-line animated-divider max-w-4xl mx-auto"}]
11:["$","section",null,{"className":"reveal-up max-w-4xl mx-auto mb-16","style":{"--reveal-delay":"1340ms"},"children":[["$","h2",null,{"className":"text-3xl font-bold text-white mb-6 tracking-wider","children":"Trade-offs and Dilemmas"}],["$","div",null,{"className":"space-y-4","children":[["$","div",null,{"className":"floating-card reveal-scale bg-[#1a1a1a] rounded-xl p-6 border border-[#2a2a2a]","style":{"--reveal-delay":"1400ms"},"children":[["$","h3",null,{"className":"text-white font-bold mb-2","children":"Fuel Economy vs. Board Position"}],["$","p",null,{"className":"text-gray-400 text-sm leading-relaxed","children":"Every movement costs Fuel. Spending Fuel aggressively to reach high-value tiles like the 2x Lab leaves you vulnerable in the next Solar Sacrifice cycle. Players must decide whether a big mining run now is worth the mobility cost later."}]]}],["$","div",null,{"className":"floating-card reveal-scale bg-[#1a1a1a] rounded-xl p-6 border border-[#2a2a2a]","style":{"--reveal-delay":"1460ms"},"children":[["$","h3",null,{"className":"text-white font-bold mb-2","children":"Solar Sacrifice: Contribute or Free-Ride?"}],["$","p",null,{"className":"text-gray-400 text-sm leading-relaxed","children":"Every round you face a silent negotiation. Paying your fair share depletes your Ark-building resources; contributing nothing risks a collective penalty that hurts everyone including you. The optimal strategy shifts based on your current resource pool and how close you are to completing an Ark slot."}]]}],["$","div",null,{"className":"floating-card reveal-scale bg-[#1a1a1a] rounded-xl p-6 border border-[#2a2a2a]","style":{"--reveal-delay":"1520ms"},"children":[["$","h3",null,{"className":"text-white font-bold mb-2","children":"Sabotage Timing"}],["$","p",null,{"className":"text-gray-400 text-sm leading-relaxed","children":"Sabotage cards are precious and single-use. Playing Sabotage Protocol at the wrong time, when the target can immediately rebuild their lost slot, wastes the card entirely. Holding it for the final few slots where rebuilding costs are heaviest maximises disruption."}]]}],["$","div",null,{"className":"floating-card reveal-scale bg-[#1a1a1a] rounded-xl p-6 border border-[#2a2a2a]","style":{"--reveal-delay":"1580ms"},"children":[["$","h3",null,{"className":"text-white font-bold mb-2","children":"Mass Relay vs. Sequential Movement"}],["$","p",null,{"className":"text-gray-400 text-sm leading-relaxed","children":"The Mass Relay lets you warp anywhere on the board for 1 Fuel but it costs your movement action. You skip all the tiles in between, meaning you miss out on passing-by effects and potential resource pickups. Sometimes the slow path is richer."}]]}],["$","div",null,{"className":"floating-card reveal-scale bg-[#1a1a1a] rounded-xl p-6 border border-[#2a2a2a]","style":{"--reveal-delay":"1640ms"},"children":[["$","h3",null,{"className":"text-white font-bold mb-2","children":"Race Ability: Now or Never?"}],["$","p",null,{"className":"text-gray-400 text-sm leading-relaxed","children":"Active race abilities cost resources and can only be used once per Action Phase. Using the Turian Covering Fire to guarantee a movement roll might get you to a key tile but leaves you without the resource buffer needed for the next sacrifice."}]]}]]}]]}]
